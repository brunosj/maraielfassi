# Copy to `.env` on the server (never commit `.env`).
# Loaded by `scripts/deploy.sh` before PM2 so production has these at runtime.
# Owner must be the deploy user (e.g. lando): `sudo chown lando:lando .env && chmod 600 .env`
# Astro/Vite does not read root `.env` during build (see `vite-env/` in astro.config.mjs).

# Shared login for https://maraielfassi.com/keystatic (HTTP Basic in Astro middleware)
KEYSTATIC_BASIC_AUTH_USER=editor
KEYSTATIC_BASIC_AUTH_PASSWORD=
