---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import HeroPicture from '../components/HeroPicture.astro';
import ServicesSection from '../components/ServicesSection.astro';
// Live SSR: Keystatic Reader (`keystaticReader` in load-live-content.ts); service HTML still Markdoc-from-disk.
import { loadServicesLive, loadSiteLive } from '../lib/load-live-content';

const site = await loadSiteLive();
const services = await loadServicesLive();

const description = site.metaDescription ?? site.tagline;
const introParagraphs = site.intro
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<Layout
  title={site.name}
  description={description}
  name={site.name}
  tagline={site.tagline}
  contactEmail={site.contactEmail}
  linkedinUrl={site.linkedinUrl}
  languages={site.languages}
>
  <div class="page-inner">
    <HeroPicture
      src={site.heroImage}
      alt={
        site.heroImageAlt?.trim()
          ? site.heroImageAlt.trim()
          : `${site.name} — hero image`
      }
    />
    <section class="hero" aria-labelledby="hero-heading">
      <div class="hero__primary">
        <h1 id="hero-heading" class="hero__name">{site.name}</h1>
        <p class="hero__tagline">{site.tagline}</p>
      </div>
    </section>

    <section class="about-band" id="about" aria-labelledby="intro-heading">
      <div class="about-band__inner">
        <div class="about-band__block about-band__content">
          <div class="intro__header">
            <h2 id="intro-heading" class="section-title">About</h2>
          </div>
          <div class="intro__body">
            {introParagraphs.map((text) => <p>{text}</p>)}
          </div>
        </div>
      </div>
    </section>

    <ServicesSection services={services} />
  </div>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-2xl) var(--space-lg);
    margin-bottom: 0;
    border-bottom: none;
  }

  @media (max-width: 40rem) {
    .hero {
      padding: var(--space-xl) var(--space-md);
    }
  }

  .hero__primary {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 4.8vw, 3rem);
    font-weight: 800;
    margin: 0;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .hero__tagline {
    margin: 0;
    max-width: none;
    width: 100%;
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  @media (min-width: 40rem) {
    .hero__tagline {
      font-size: clamp(1.4rem, 2.4vw, 1.8rem);
      line-height: 1.48;
    }
  }

  .page-inner > .about-band {
    border-bottom: var(--border-strong);
  }

  .about-band {
    margin: 0;
    padding: 0;
    border-top: var(--border-strong);
  }

  .about-band__inner {
    display: grid;
    gap: 0;
    grid-template-columns: 1fr;
  }

  .about-band__block {
    padding: var(--space-xl) var(--space-lg);
    border-bottom: var(--border-thin);
  }

  @media (max-width: 39.99rem) {
    .about-band__block {
      padding: var(--space-lg) var(--space-md);
    }
  }

  @media (min-width: 40rem) {
    .about-band__block {
      border-bottom: none;
    }
  }

  .about-band__content {
    min-width: 0;
  }

  .about-band .section-title {
    border-bottom: none;
    padding-bottom: 0;
  }

  .intro__header {
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 40rem) {
    .intro__header {
      margin-bottom: var(--space-md);
    }
  }

  .intro__body {
    max-width: var(--content-max);
    font-family: var(--font-body);
  }

  @media (min-width: 40rem) {
    .intro__body {
      max-width: 100%;
    }
  }

  .intro__body p {
    margin: 0 0 var(--space-md);
  }

  .intro__body p:last-child {
    margin-bottom: 0;
  }
</style>
