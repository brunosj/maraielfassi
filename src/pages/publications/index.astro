---
export const prerender = false;

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PublicationList from '../../components/PublicationList.astro';

const siteList = await getCollection('site');
const siteEntry = siteList[0];
if (!siteEntry) throw new Error('Missing site content');

const site = siteEntry.data;
const publications = await getCollection('publications');

const description = `Publications and videos by ${site.name}: articles, reports, policy briefs, and more.`;
---

<Layout
  title="Publications"
  description={description}
  name={site.name}
  tagline={site.tagline}
  contactEmail={site.contactEmail}
  linkedinUrl={site.linkedinUrl}
  languages={site.languages}
>
  <div class="page-inner">
    <header class="page-header">
      <h1 class="page-title">Publications</h1>
      <p class="page-header__lede">
        Selected articles, reports, policy outputs, and videos. 
      </p>
    </header>
    <PublicationList publications={publications} />
  </div>
</Layout>

<style>
  .page-inner > .page-header {
    border-bottom: none;
  }

  .page-header {
    padding: var(--space-xl) var(--space-md);
    margin-bottom: 0;
  }

  @media (min-width: 40.01rem) {
    .page-header {
      padding-left: var(--space-lg);
      padding-right: var(--space-lg);
    }
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
    text-transform: uppercase;
  }

  @media (max-width: 40rem) {
    .page-title {
      font-size: clamp(1.35rem, 5.5vw + 0.35rem, 1.85rem);
    }
  }

  .page-header__lede {
    margin: 0;
    max-width: 36rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
